{
    "assistant": {
        "default_model": {
            "model": "claude-3-5-sonnet-20240620",
            "provider": "zed.dev"
        },
        "version": "2"
    },
    "auto_install_extensions": {
        "dockerfile": true,
        "git-firefly": true,
        "html": true,
        "ruff": true,
        "toml": true
    },
    "buffer_font_family": "Fira Mono",
    "buffer_font_size": 16,
    "buffer_line_height": {
        "custom": 2
    },
    "cursor_blink": false,
    "features": {
        "inline_completion_provider": "supermaven"
    },
    "file_scan_exclusions": [
        "**/.git",
        "**/.ruff_cache",
        "**/__pycache__",
        "**/.venv"
    ],
    "formatter": "prettier",
    "indent_guides": {
        "enabled": false
    },
    "languages": {
        "Python": {
            "formatter": [
                {
                    "language_server": {
                        "name": "ruff"
                    }
                }
            ],
            "language_servers": ["pyright", "ruff"]
        }
    },
    "lsp": {
        "pyright": {
            "settings": {
                "python.analysis": {
                    "ignore": ["*"]
                }
            }
        }
    },
    "project_panel": {
        "auto_fold_dirs": false
    },
    "show_completion_documentation": false,
    "show_signature_help_after_edits": false,
    "terminal": {
        "blinking": "off",
        "env": {
            "EDITOR": "zed --wait"
        }
    },
    "theme": {
        "dark": "Rosé Pine",
        "light": "Rosé Pine Dawn",
        "mode": "system"
    },
    "ui_font_family": "Fira Mono",
    "ui_font_size": 16,
    "vim_mode": true,
    "wrap_guides": [80]
}
